{
  "experimental": {
    "api": {
      "listen": "127.0.0.1:10086",
      "stats": true
    }
  },
  "inbounds": [
    {
      "type": "hysteria2",
      "tag": "hy2-inbound",
      "listen": "::",
      "listen_port": 8086,
      "users": [
        {
          "name": "killpv2_user1",
          "password": "killpv2_secret_pass"
        }
      ],
      "tls": {
        "enabled": true,
        "server_name": "bing.com",
        "alpn": [
          "h3"
        ],
        "certificate_path": "/usr/local/etc/xray/cert.pem",
        "key_path": "/usr/local/etc/xray/privkey.pem"
      }
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    }
  ]
}
